{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        ".validate": "newData.hasChildren(['id', 'fullName', 'email', 'role', 'accountStatus'])",

        "role": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || !data.exists()"
        },
        "accountStatus": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || !data.exists() || newData.val() === data.val()"
        }
      }
    },

    "jobSeekerProfiles": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'COMPANY')",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "companies": {
      ".read": "auth != null",
      "$companyId": {
        ".write": "auth != null && (data.child('ownerUserId').val() === auth.uid || (!data.exists() && newData.child('ownerUserId').val() === auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",

        "verificationStatus": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || newData.val() === 'PENDING' || newData.val() === data.val() || !data.exists()"
        },
        "verifiedAt": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || newData.val() === data.val() || !data.exists()"
        },
        "verifiedBy": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || newData.val() === data.val() || !data.exists()"
        },
        "rejectionReason": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || newData.val() === data.val() || !data.exists()"
        },
        "ownerUserId": {
          ".validate": "!data.exists() || newData.val() === data.val()"
        }
      }
    },

    "companyDocuments": {
      "$companyId": {
        ".read": "auth != null && (root.child('companies').child($companyId).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        ".write": "auth != null && (root.child('companies').child($companyId).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')"
      }
    },

    "jobCategories": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'ADMIN'"
    },

    "jobs": {
      ".read": "auth != null",
      "$jobId": {
        ".write": "auth != null && (root.child('companies').child(data.child('companyId').val()).child('ownerUserId').val() === auth.uid || (!data.exists() && root.child('companies').child(newData.child('companyId').val()).child('ownerUserId').val() === auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",

        "moderationStatus": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || newData.val() === data.val() || !data.exists()"
        },
        "moderationReason": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || newData.val() === data.val() || !data.exists()"
        },
        "companyId": {
          ".validate": "!data.exists() || newData.val() === data.val()"
        }
      }
    },

    "companyJobs": {
      "$companyId": {
        ".read": "auth != null && (root.child('companies').child($companyId).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        ".write": "auth != null && (root.child('companies').child($companyId).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')"
      }
    },

    "applications": {
      "$applicationId": {
        ".read": "auth != null && (data.child('applicantId').val() === auth.uid || root.child('companies').child(data.child('companyId').val()).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        ".write": "auth != null && ((!data.exists() && newData.child('applicantId').val() === auth.uid) || data.child('applicantId').val() === auth.uid || root.child('companies').child(data.child('companyId').val()).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",

        "applicantId": {
          ".validate": "!data.exists() || newData.val() === data.val()"
        },
        "resumeUrl": {
          ".validate": "!data.exists() || newData.val() === data.val() || data.parent().child('applicantId').val() === auth.uid"
        },
        "coverLetter": {
          ".validate": "!data.exists() || newData.val() === data.val() || data.parent().child('applicantId').val() === auth.uid"
        },
        "status": {
          ".validate": "!data.exists() || data.parent().child('applicantId').val() === auth.uid || root.child('companies').child(data.parent().child('companyId').val()).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN'"
        }
      }
    },

    "userApplications": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "jobApplications": {
      "$jobId": {
        ".read": "auth != null && (root.child('companies').child(root.child('jobs').child($jobId).child('companyId').val()).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        "$applicationId": {
          ".write": "auth != null && ((!data.exists() && root.child('applications').child($applicationId).child('applicantId').val() === auth.uid && root.child('applications').child($applicationId).child('jobId').val() === $jobId) || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')"
        }
      }
    },

    "companyApplications": {
      "$companyId": {
        ".read": "auth != null && (root.child('companies').child($companyId).child('ownerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        "$applicationId": {
          ".write": "auth != null && ((!data.exists() && root.child('applications').child($applicationId).child('applicantId').val() === auth.uid && root.child('applications').child($applicationId).child('companyId').val() === $companyId) || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')"
        }
      }
    },

    "savedJobs": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "reports": {
      "$reportId": {
        ".read": "auth != null && (data.child('reporterId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        ".write": "auth != null && ((!data.exists() && newData.child('reporterId').val() === auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",

        "reporterId": {
          ".validate": "!data.exists() || newData.val() === data.val()"
        }
      }
    },

    "notifications": {
      "$recipientId": {
        ".read": "auth != null && $recipientId === auth.uid",
        ".indexOn": ["isRead", "createdAt"],
        "$notificationId": {
          ".write": "auth != null && ((data.exists() && $recipientId === auth.uid && newData.child('id').val() === data.child('id').val() && newData.child('recipientId').val() === data.child('recipientId').val() && newData.child('senderId').val() === data.child('senderId').val() && newData.child('type').val() === data.child('type').val() && newData.child('relatedEntityType').val() === data.child('relatedEntityType').val() && newData.child('relatedEntityId').val() === data.child('relatedEntityId').val() && newData.child('secondaryEntityId').val() === data.child('secondaryEntityId').val() && newData.child('createdAt').val() === data.child('createdAt').val()) || (!data.exists() && newData.child('id').val() === $notificationId && newData.child('recipientId').val() === $recipientId && newData.child('senderId').val() === auth.uid && ((newData.child('type').val() === 'APPLICATION_SUBMITTED' && $recipientId === auth.uid) || (newData.child('type').val() === 'NEW_APPLICATION' && root.child('applications').child(newData.child('relatedEntityId').val()).child('applicantId').val() === auth.uid && root.child('companies').child(root.child('applications').child(newData.child('relatedEntityId').val()).child('companyId').val()).child('ownerUserId').val() === $recipientId) || (newData.child('relatedEntityType').val() === 'APPLICATION' && root.child('applications').child(newData.child('relatedEntityId').val()).child('applicantId').val() === $recipientId && root.child('companies').child(root.child('applications').child(newData.child('relatedEntityId').val()).child('companyId').val()).child('ownerUserId').val() === auth.uid) || (newData.child('relatedEntityType').val() === 'COMPANY' && root.child('companies').child(newData.child('relatedEntityId').val()).child('ownerUserId').val() === auth.uid && root.child('users').child($recipientId).child('role').val() === 'ADMIN') || (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' && (newData.child('relatedEntityType').val() === 'COMPANY' || newData.child('relatedEntityType').val() === 'JOB' || newData.child('relatedEntityType').val() === 'REPORT')) || (newData.child('type').val() === 'NEW_JOB_REPORT' && root.child('reports').child(newData.child('relatedEntityId').val()).child('reporterId').val() === auth.uid && root.child('users').child($recipientId).child('role').val() === 'ADMIN'))))",
          ".validate": "newData.hasChildren(['id', 'recipientId', 'senderId', 'type', 'relatedEntityType', 'relatedEntityId', 'isRead', 'createdAt'])"
        }
      }
    },

    "userDevices": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN')",
        "$deviceId": {
          ".write": "auth != null && $uid === auth.uid",
          ".validate": "newData.hasChildren(['deviceId', 'token', 'platform', 'active', 'createdAt', 'updatedAt']) && newData.child('deviceId').val() === $deviceId && newData.child('platform').val() === 'android'"
        }
      }
    },

    "adminActivities": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'ADMIN'",
      "$activityId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'ADMIN' && !data.exists()"
      }
    }
  }
}
